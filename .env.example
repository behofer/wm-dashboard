# Environment for the WC2026 proxy (server.js).
# Copy this to a real env file on the server (e.g. /etc/wm-dashboard.env) and
# fill in your key. NEVER commit the real .env — this example only documents the
# variables. server.js reads them straight from the process environment.

# Required for official live data (api-sports.io / API-Football, PAID plan).
API_FOOTBALL_KEY=your-api-football-key

# --- Optional ---
# Listen port (the systemd service / reverse proxy target).
PORT=8787

# Restrict CORS to your domain in production, e.g. https://wm.example.com
ALLOW_ORIGIN=*

# Season used to resolve a player's club on the player page.
PLAYER_CLUB_SEASON=2025

# Adaptive background poll intervals in ms (defaults shown).
# LIVE_POLL_MS=30000
# SOON_POLL_MS=60000
# IDLE_POLL_MS=600000
